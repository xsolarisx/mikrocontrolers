{
  "version": 1,
  "author": "current-logger",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "wokwi-potentiometer",
      "id": "pot1",
      "top": 160,
      "left": 240,
      "attrs": {}
    },
    { "type": "wokwi-resistor", "id": "r_bias1", "top": 80,  "left": 340, "rotate": 90, "attrs": { "value": "10000" } },
    { "type": "wokwi-resistor", "id": "r_bias2", "top": 120, "left": 340, "rotate": 90, "attrs": { "value": "10000" } }
  ],
  "connections": [
    ["esp:TX0",   "$serialMonitor:RX", "", []],
    ["esp:RX0",   "$serialMonitor:TX", "", []],
    ["esp:3V3",   "r_bias1:1", "red",   []],
    ["r_bias1:2", "r_bias2:1", "orange", []],
    ["r_bias2:2", "esp:GND.1", "black", []],
    ["r_bias1:2", "pot1:SIG",  "yellow", []],
    ["pot1:VCC",  "esp:3V3",   "red",   []],
    ["pot1:GND",  "esp:GND.1", "black", []],
    ["pot1:SIG",  "esp:D34",   "yellow", []]
  ],
  "notes": [
    "Real hardware: replace potentiometer with ZMCT103C / SCT-013-030 CT sensor.",
    "Burden resistor (62 ohm for SCT-013-030, 100 ohm for ZMCT103C) connects CT output to bias midpoint.",
    "Bias midpoint (2x 10k from 3.3V to GND) sets DC offset at 1.65V.",
    "AC signal from CT swings above/below 1.65V — ESP32 ADC reads 0-3.3V range."
  ]
}
